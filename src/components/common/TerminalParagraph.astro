---
type Props = {
  children: string;
  class?: string;
  variant?: 'primary' | 'secondary' | 'dim';
};

const { children, variant = 'primary', class: className = '' } = Astro.props;

// Map variants to terminal-appropriate styles
const variantStyles = {
  primary: 'text-green-400',
  secondary: 'text-green-500',
  dim: 'text-green-600'
};

const sizeClass = variantStyles[variant];
---

<!-- Terminal-style paragraph with variant support -->
<p class={`my-6 leading-relaxed ${sizeClass} ${className}`}>
  {children}
</p>