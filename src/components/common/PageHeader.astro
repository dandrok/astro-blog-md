---
/**
 * Site header chrome: brand link + kitbash theme/preset toggles.
 */
type Props = {
  showBackButton?: boolean;
  backText?: string;
  backUrl?: string;
};

const { showBackButton = false, backText = 'cd ..', backUrl = '/' } = Astro.props;
---

<header class={`flex h-16 items-center justify-between ${showBackButton ? 'mb-6' : 'mb-12'}`}>
  <a
    href="/"
    class="text-xl font-bold text-green-500 no-underline transition-colors hover:text-green-400"
  >
    ~/.file
  </a>
  <div class="flex items-center gap-4">
    <kitbash-toggle-group>
      <!-- Defaults: storageKey theme / ui-mode (blog-compatible). -->
      <kitbash-theme-toggle></kitbash-theme-toggle>
      <kitbash-preset-toggle></kitbash-preset-toggle>
    </kitbash-toggle-group>
  </div>
</header>

{
  showBackButton && (
    <nav aria-label="Breadcrumb" class="mb-10">
      <a
        href={backUrl}
        data-back-btn
        class="group inline-flex items-center gap-2 text-green-500 no-underline transition-colors hover:text-green-400"
      >
        <span class="transition-transform group-hover:-translate-x-1">←</span> {backText}
      </a>
    </nav>
  )
}

<script>
  function setupBackButton() {
    const backBtn = document.querySelector('a[data-back-btn]');
    if (!backBtn) return;

    let isInternalReferrer = false;
    if (document.referrer) {
      try {
        const referrerUrl = new URL(document.referrer);
        isInternalReferrer = referrerUrl.host === window.location.host;
      } catch {
        // Invalid URL
      }
    }

    if (!isInternalReferrer) return;

    backBtn.addEventListener('click', (e) => {
      const mouseEvent = e as MouseEvent;
      if (mouseEvent.ctrlKey || mouseEvent.metaKey || mouseEvent.shiftKey) return;
      e.preventDefault();
      history.back();
    });
  }

  /** Optional glitch / smooth body class when UI preset flips (blog polish). */
  function setupPresetTransition() {
    const preset = document.querySelector('kitbash-preset-toggle') as HTMLElement | null;
    if (!preset || preset.dataset.transitionBound === '1') return;
    preset.dataset.transitionBound = '1';

    preset.addEventListener('kitbash-change', (ev) => {
      // kitbash-change detail: { props, state } — not a flat value
      const props = (ev as CustomEvent<{ props?: { value?: string } }>).detail?.props;
      const next = props?.value;
      if (next !== 'terminal' && next !== 'default') return;

      document.body.classList.remove('glitch-transition', 'smooth-transition');
      void document.body.offsetWidth;

      if (next === 'terminal') {
        document.body.style.setProperty('--scroll-y', `${window.scrollY}px`);
        document.body.classList.add('glitch-transition');
        window.setTimeout(() => document.body.classList.remove('glitch-transition'), 400);
      } else {
        document.body.classList.add('smooth-transition');
        window.setTimeout(() => document.body.classList.remove('smooth-transition'), 400);
      }
    });
  }

  function initHeader() {
    setupBackButton();
    setupPresetTransition();
  }

  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>
