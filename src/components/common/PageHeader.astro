---
type Props = {
  showBackButton?: boolean;
  backText?: string;
  backUrl?: string;
};

const { showBackButton = false, backText = "cd ..", backUrl = "/" } = Astro.props;
---

<header class="flex items-center justify-between mb-12 h-16">
  <a href="/" class="text-green-500 font-bold text-xl hover:text-green-400 no-underline transition-colors">
    ~/.file
  </a>
  {showBackButton && (
    <a href={backUrl} class="text-green-500 hover:text-green-400 no-underline transition-colors group flex items-center gap-2">
      <span class="group-hover:-translate-x-1 transition-transform">←</span> {backText}
    </a>
  )}
</header>