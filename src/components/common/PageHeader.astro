---
import ThemeToggle from './ThemeToggle.astro';

type Props = {
  showBackButton?: boolean;
  backText?: string;
  backUrl?: string;
};

const { showBackButton = false, backText = 'cd ..', backUrl = '/' } = Astro.props;
---

<header class="mb-12 flex h-16 items-center justify-between">
  <a
    href="/"
    class="text-xl font-bold text-green-500 no-underline transition-colors hover:text-green-400"
  >
    ~/.file
  </a>
  <div class="flex items-center gap-3">
    {
      showBackButton && (
        <a
          href={backUrl}
          class="group flex items-center gap-2 text-green-500 no-underline transition-colors hover:text-green-400"
        >
          <span class="transition-transform group-hover:-translate-x-1">←</span> {backText}
        </a>
      )
    }
    <ThemeToggle />
  </div>
</header>
