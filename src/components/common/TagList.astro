---
/**
 * Thin Astro adapter over `@ktbsh/ui` tag chips.
 * Articles / lists pass string tags; MD body styles stay site-owned.
 */
type Props = {
  tags?: string[];
  class?: string;
};

const { tags = [], class: className = '' } = Astro.props;
const items = tags.filter((t) => typeof t === 'string' && t.trim().length > 0);
---

{
  items.length > 0 && (
    <kitbash-tag-list class:list={[className]}>
      {items.map((tag) => (
        <kitbash-tag>{tag}</kitbash-tag>
      ))}
    </kitbash-tag-list>
  )
}
