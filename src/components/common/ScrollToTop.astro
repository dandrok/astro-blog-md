---
/**
 * Fixed scroll-to-top control via `@ktbsh/ui` `kitbash-scroll-top`.
 * Visibility + desktop gutter position are owned by this host script
 * (CE has no window scroll lifecycle — by design).
 */
---

<kitbash-scroll-top
  id="scroll-to-top"
  caption="$ top"
  label="Scroll to top"
  behavior="smooth"
></kitbash-scroll-top>

<script>
  type ScrollTopEl = HTMLElement & {
    visible?: boolean;
  };

  function setupScrollTop() {
    const scrollBtn = document.getElementById('scroll-to-top') as ScrollTopEl | null;
    const mainContent = document.getElementById('main-content');
    if (!scrollBtn) return;

    const setVisible = () => {
      const show = window.scrollY > 300;
      // Boolean attribute + property for CE prop systems
      scrollBtn.visible = show;
      if (show) scrollBtn.setAttribute('visible', '');
      else scrollBtn.removeAttribute('visible');
    };

    const setButtonPosition = () => {
      if (!mainContent) {
        scrollBtn.style.right = '1rem';
        scrollBtn.style.left = 'auto';
        return;
      }
      if (window.innerWidth < 1024) {
        scrollBtn.style.right = '1rem';
        scrollBtn.style.left = 'auto';
      } else {
        const mainRect = mainContent.getBoundingClientRect();
        const rightOffset = Math.max(24, window.innerWidth - mainRect.right - 24);
        scrollBtn.style.right = `${rightOffset}px`;
        scrollBtn.style.left = 'auto';
      }
    };

    setVisible();
    setButtonPosition();

    window.addEventListener('scroll', setVisible, { passive: true });
    window.addEventListener('resize', setButtonPosition, { passive: true });
  }

  setupScrollTop();
  document.addEventListener('astro:page-load', setupScrollTop);
</script>
