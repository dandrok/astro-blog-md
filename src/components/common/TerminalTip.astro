---
import PulseCursor from './PulseCursor.astro';

type Props = {
  title?: string;
  content: string;
  type?: 'tip' | 'note' | 'pro';
  class?: string;
};

const { title, content, type = 'tip', class: className = '' } = Astro.props;

const tipTitles = {
  tip: 'TIP',
  note: 'NOTE',
  pro: 'PRO TIP'
};

const displayTitle = title || tipTitles[type];
---

<!-- Terminal-style tip/note block -->
<div class={`my-8 px-6 py-4 border-l-2 border-l-terminal-border bg-terminal-bg/50 text-terminal-text-muted ${className}`}>
  <p class="my-4 leading-relaxed">
    <strong class="text-terminal-text-secondary" style="font-style: normal;">{displayTitle}:</strong> {content}
  </p>
</div>