---
const today = new Date();
---

<!-- Minimalist terminal footer -->
<footer class="terminal-footer">
  <div class="terminal-footer-content">
    <!-- Line 1: Social links -->
    <div class="terminal-footer-social">
      <a href="https://m.webtoo.ls/@astro" target="_blank" rel="me" class="terminal-footer-link">[Mastodon]</a>
      <a href="https://twitter.com/astrodotbuild" target="_blank" class="terminal-footer-link">[Twitter]</a>
      <a href="https://github.com/withastro/astro" target="_blank" class="terminal-footer-link">[GitHub]</a>
    </div>

    <!-- Line 2: Creator/Copyright -->
    <div class="terminal-footer-copyright">
      <span class="terminal-dim">Made by dandrok © {today.getFullYear()}</span>
    </div>
  </div>
</footer>

<style>
  .terminal-footer {
    background: var(--terminal-bg-code);
    border-top: 1px solid var(--terminal-border);
    margin-top: 4rem;
    padding: 1.5rem 1rem; /* Reduced padding for minimalist design */
    color: var(--terminal-text);
  }

  .terminal-footer-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.75rem; /* Clean spacing between the two lines */
  }

  .terminal-footer-social {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .terminal-footer-copyright {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .terminal-footer-link {
    padding: 0.25rem 0.75rem;
    background: transparent;
    border: 1px solid var(--terminal-border);
    color: var(--terminal-text-dim);
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .terminal-footer-link:hover {
    color: var(--terminal-text-bright);
    border-color: var(--terminal-link);
    text-shadow: 0 0 3px var(--terminal-link);
  }

  @media (max-width: 768px) {
    .terminal-footer {
      padding: 1rem 0.75rem; /* Compact on mobile */
    }

    .terminal-footer-content {
      gap: 0.5rem;
    }

    .terminal-footer-social {
      gap: 0.25rem;
    }

    .terminal-footer-link {
      padding: 0.2rem 0.5rem;
      font-size: 0.7rem;
    }
  }
</style>
