<footer class="mx-auto mt-auto max-w-6xl px-6 py-12 text-base">
  <nav
    aria-label="Footer links"
    class="flex flex-col gap-4 border-t border-green-400/20 pt-6 text-green-500/70 lg:flex-row lg:items-center lg:justify-between"
  >
    <div>
      <span class="font-bold text-green-500">$</span> cat ~/.file/links
    </div>

    <ul class="m-0 flex list-none flex-wrap gap-x-6 gap-y-3 p-0 text-green-400">
      <li>
        <a
          href="https://github.com/dandrok"
          target="_blank"
          rel="noopener noreferrer"
          class="no-underline transition-colors hover:text-green-300"
        >
          github=github.com/dandrok
        </a>
      </li>
      <li>
        <a
          href="#"
          id="email-link"
          data-u="cngelx.fghfvx"
          data-d="tznvy"
          data-t="pbz"
          class="no-underline transition-colors hover:text-green-300"
        >
          email=[protected]
        </a>
        <noscript>
          <style>
            #email-link {
              display: none !important;
            }
          </style>
          <span>email=patryk.stusik [at] gmail [dot] com</span>
        </noscript>
      </li>
      <li>
        <a href="/blog/" class="no-underline transition-colors hover:text-green-300">
          blog=/blog
        </a>
      </li>
      <li>
        <a href="/rss.xml" class="no-underline transition-colors hover:text-green-300">
          rss=/rss.xml
        </a>
      </li>
    </ul>
  </nav>
</footer>

<script>
  function rot13(str: string): string {
    return str.replace(/[a-zA-Z]/g, (c) => {
      const code = c.charCodeAt(0);
      const limit = c <= 'Z' ? 90 : 122;
      const rotated = code + 13;
      return String.fromCharCode(limit >= rotated ? rotated : rotated - 26);
    });
  }

  function setupEmailObfuscation() {
    const emailLink = document.getElementById('email-link') as HTMLAnchorElement | null;
    if (!emailLink) return;

    const u = emailLink.getAttribute('data-u');
    const d = emailLink.getAttribute('data-d');
    const t = emailLink.getAttribute('data-t');
    if (!u || !d || !t) return;

    const email = `${rot13(u)}@${rot13(d)}.${rot13(t)}`;

    const reveal = () => {
      emailLink.href = `mailto:${email}`;
      emailLink.textContent = `email=${email}`;
    };

    emailLink.addEventListener('mouseenter', reveal, { once: true });
    emailLink.addEventListener('focus', reveal, { once: true });
    emailLink.addEventListener('click', reveal);
  }

  setupEmailObfuscation();
  document.addEventListener('astro:page-load', setupEmailObfuscation);
</script>
