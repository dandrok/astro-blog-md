---
import type { MarkdownHeading } from 'astro';

/**
 * In-page TOC via `kitbash-toc` (light-DOM heading links + built-in scroll-spy).
 * Markdown headings stay native in the article; this only styles the nav.
 */
interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth > 1 && h.depth < 4);
---

{
  filteredHeadings.length > 0 && (
    /*
      Sticky / max-height / overflow are on the <aside> in BlogPost (grid item).
      Do not put sticky on kitbash-toc — :host is already a scrollport and nested
      sticky here failed to stay visible while scrolling the article.
    */
    <div class="toc-sidebar">
      <kitbash-toc label="// Contents">
        {filteredHeadings.map((heading) => (
          <a
            href={`#${heading.slug}`}
            data-depth={String(heading.depth)}
            data-slug={heading.slug}
          >
            {heading.text}
          </a>
        ))}
      </kitbash-toc>
    </div>
  )
}
