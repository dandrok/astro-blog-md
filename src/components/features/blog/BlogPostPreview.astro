---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../../FormattedDate.astro';

type Props = {
  post: CollectionEntry<'blog'>;
  showDescription?: boolean;
};

const { post, showDescription = true } = Astro.props;
const filename = `${post.id}${post.id.endsWith('.mdx') ? '' : '.md'}`;
---

<li>
  <a
    href={`/blog/${post.id}/`}
    class="block p-6 border border-green-400/20 bg-black/15 hover:bg-black/25 no-underline group transition-colors focus:outline-none focus:ring-2 focus:ring-green-400/50"
  >
    <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
      <p class="text-green-500 text-sm leading-relaxed">
        -rw-r--r-- <FormattedDate date={post.data.pubDate} /> {filename}
      </p>
    </div>

    <div class="mt-4 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div class="min-w-0">
        <p class="text-green-500 text-sm mb-2">
          # {filename}
        </p>
        <h2 class="text-2xl text-green-200 group-hover:text-green-100 transition-colors leading-tight">
          {post.data.title}
        </h2>
      </div>
    </div>

    {showDescription && post.data.description && (
      <p class="mt-5 text-green-400 leading-relaxed max-w-3xl group-hover:text-green-300 transition-colors">
        // {post.data.description}
      </p>
    )}
  </a>
</li>
