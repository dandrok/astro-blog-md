---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../../FormattedDate.astro';

type Props = {
  post: CollectionEntry<'blog'>;
  showDescription?: boolean;
};

const { post, showDescription = true } = Astro.props;
const filename = `${post.id}${post.id.endsWith('.mdx') ? '' : '.md'}`;
---

<li>
  <a
    href={`/blog/${post.id}/`}
    class="group block border border-green-400/20 bg-black/15 p-6 no-underline transition-colors hover:bg-black/25 focus:ring-2 focus:ring-green-400/50 focus:outline-none"
  >
    <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
      <p class="text-sm leading-relaxed text-green-500">
        -rw-r--r-- <FormattedDate date={post.data.pubDate} />
        {filename}
      </p>
    </div>

    <div class="mt-4 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div class="min-w-0">
        <p class="mb-2 text-sm text-green-500">
          # {filename}
        </p>
        <h2
          class="text-2xl leading-tight text-green-200 transition-colors group-hover:text-green-100"
        >
          {post.data.title}
        </h2>
      </div>
    </div>

    {
      showDescription && post.data.description && (
        <p class="mt-5 max-w-3xl leading-relaxed text-green-400 transition-colors group-hover:text-green-300">
          // {post.data.description}
        </p>
      )
    }
  </a>
</li>
