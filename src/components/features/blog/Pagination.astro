---
/**
 * URL-based prev/next for multi-page routes.
 * Uses kitbash-link (not kitbash-pagination buttons) so MPA navigation stays
 * progressive and shareable — matches Astro static pagination.
 */
type Props = {
  currentPage: number;
  lastPage: number;
  prevUrl?: string;
  nextUrl?: string;
};

const { currentPage, lastPage, prevUrl, nextUrl } = Astro.props;
---

<nav class="mt-16 flex items-center justify-between gap-4" aria-label="Pagination">
  {
    prevUrl ? (
      <kitbash-link href={prevUrl} tone="accent">
        &lt; prev
      </kitbash-link>
    ) : (
      <span class="text-green-900" aria-disabled="true">
        &lt; prev
      </span>
    )
  }

  <span class="text-green-700" aria-current="page">
    {currentPage} / {lastPage}
  </span>

  {
    nextUrl ? (
      <kitbash-link href={nextUrl} tone="accent">
        next &gt;
      </kitbash-link>
    ) : (
      <span class="text-green-900" aria-disabled="true">
        next &gt;
      </span>
    )
  }
</nav>
