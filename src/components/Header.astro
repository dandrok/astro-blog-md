---
import { SITE_TITLE } from '../consts';
---

<!-- Navigation with consistent spacing and accessibility improvements -->
<nav
  class="flex flex-col md:flex-row md:items-center md:justify-between items-stretch gap-4 p-6 bg-green-400/5 border-b border-green-400/30 mb-8 mt-0"
  role="navigation"
  aria-label="Main navigation"
>
  <!-- Site title/brand -->
  <div class="flex items-center">
    <span
      class="text-green-300 font-normal text-xl before:content-['$'] before:text-green-400 before:mr-2"
      role="heading"
      aria-level="1"
    >
      ~/{SITE_TITLE}
    </span>
  </div>

  <!-- Navigation menu with consistent button spacing -->
  <div
    class="flex flex-wrap items-center gap-3"
    role="menubar"
    aria-label="Site navigation menu"
  >
    <a
      href="/"
      class="px-4 py-2 min-w-[44px] min-h-[44px] bg-transparent border border-green-400/30 text-green-400 text-sm font-mono transition-all duration-200 ease-in-out no-underline inline-flex items-center justify-center hover:bg-green-400/10 hover:border-green-400 hover:text-green-300 focus:outline-none focus:ring-2 focus:ring-green-400 focus:ring-offset-2 focus:ring-offset-black rounded"
      role="menuitem"
      aria-label="Navigate to home page"
    >
      [ Home ]
    </a>
    <a
      href="/blog"
      class="px-4 py-2 min-w-[44px] min-h-[44px] bg-transparent border border-green-400/30 text-green-400 text-sm font-mono transition-all duration-200 ease-in-out no-underline inline-flex items-center justify-center hover:bg-green-400/10 hover:border-green-400 hover:text-green-300 focus:outline-none focus:ring-2 focus:ring-green-400 focus:ring-offset-2 focus:ring-offset-black rounded"
      role="menuitem"
      aria-label="Navigate to blog posts"
    >
      [ Blog ]
    </a>
    <a
      href="/about"
      class="px-4 py-2 min-w-[44px] min-h-[44px] bg-transparent border border-green-400/30 text-green-400 text-sm font-mono transition-all duration-200 ease-in-out no-underline inline-flex items-center justify-center hover:bg-green-400/10 hover:border-green-400 hover:text-green-300 focus:outline-none focus:ring-2 focus:ring-green-400 focus:ring-offset-2 focus:ring-offset-black rounded"
      role="menuitem"
      aria-label="Navigate to about page"
    >
      [ About ]
    </a>
      <!--<button
      class="px-4 py-2 min-w-[44px] min-h-[44px] bg-transparent border border-green-400/30 text-green-300 text-sm font-mono transition-all duration-300 ease-in-out no-underline inline-flex items-center justify-center hover:bg-green-400/10 hover:border-green-400 hover:text-green-200 focus:outline-none focus:ring-2 focus:ring-green-400 focus:ring-offset-2 focus:ring-offset-black rounded font-semibold"
      onclick="showTerminal(); this.setAttribute('aria-expanded', 'true');"
      onkeydown="if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); showTerminal(); this.setAttribute('aria-expanded', 'true'); }"
      aria-label="Open terminal emulator"
      aria-expanded="false"
      aria-controls="terminal-container"
      role="menuitem"
      type="button"
    >
      [ Terminal ]
    </button>-->
  </div>
</nav>
