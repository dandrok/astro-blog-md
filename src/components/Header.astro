---
import { SITE_TITLE } from '../consts';
---

<!-- Terminal-style navigation -->
<nav class="terminal-nav">
  <div class="terminal-nav-left">
    <span class="terminal-prompt"></span>
    <span class="terminal-bright">./{SITE_TITLE}</span>
  </div>

  <div class="terminal-nav-right">
    <a href="/" class="terminal-nav-item">[Home]</a>
    <a href="/blog" class="terminal-nav-item">[Blog]</a>
    <a href="/about" class="terminal-nav-item">[About]</a>
    <button
      class="mode-toggle terminal-nav-item"
      data-mode="blog"
      onclick="toggleMode()"
      aria-label="Toggle terminal mode"
    >
      [BLOG]
    </button>
  </div>
</nav>

<style>
  .terminal-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    background: var(--terminal-bg-code);
    border-bottom: 1px solid var(--terminal-border);
    margin-bottom: 2rem;
    margin-top: 0;
  }

  .terminal-nav-left {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .terminal-nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .terminal-nav-item {
    padding: 0.5rem 1rem;
    background: transparent;
    border: 1px solid var(--terminal-border);
    color: var(--terminal-text);
    font-family: inherit;
    font-size: 0.9rem;
    line-height: 1.2;
    min-height: 32px;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .terminal-nav-item:hover,
  .terminal-nav-item.active {
    background: var(--terminal-bg-hover);
    border-color: var(--terminal-link);
    color: var(--terminal-text-bright);
    text-shadow: 0 0 4px var(--terminal-link);
  }

  @media (max-width: 768px) {
    .terminal-nav {
      flex-direction: column;
      gap: 0.5rem;
      align-items: stretch;
    }

    .terminal-nav-left,
    .terminal-nav-right {
      justify-content: center;
    }
  }
</style>
