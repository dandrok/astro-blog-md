---
import BaseHead from '../components/BaseHead.astro';
import { Terminal } from '../components/features/Terminal';

// Props interface
type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.css" />
    <style>
      /* Terminal container styles */
      .terminal-container {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgb(5 10 5 / 1); /* #050a05 - very dark green-gray */
        z-index: -1000;
        visibility: hidden;
        opacity: 0;
        transition-property: opacity;
        transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
        transition-duration: 200ms;
        margin: 0;
        padding: 0;
        overflow: hidden;
      }

      .terminal-container.active {
        z-index: 9999;
        visibility: visible;
        opacity: 1;
      }

      /* Make sure xterm takes full container space */
      .terminal-container.active :global(.xterm) {
        width: 100%;
        height: 100%;
      }

      /* Hide all xterm scrollbars */
      .terminal-container.active :global(.xterm-screen) {
        overflow: hidden !important;
      }

      .terminal-container.active :global(.xterm-viewport) {
        overflow: hidden !important;
      }

      .terminal-container.active :global(.xterm) {
        overflow: hidden !important;
      }
    </style>
  </head>
  <body>
    <!-- Skip to main content link for accessibility -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-gray-900 text-white px-4 py-2 rounded border border-green-400 z-50">
      Skip to main content
    </a>

    <!-- Skip to terminal link for accessibility -->
    <a href="#terminal-container" class="sr-only focus:not-sr-only focus:absolute focus:top-16 focus:left-4 bg-gray-900 text-white px-4 py-2 rounded border border-green-400 z-50">
      Skip to terminal
    </a>

    <!-- Blog Content (main content when terminal is hidden) -->
    <main id="main-content" role="main">
      <slot />
    </main>

    <!-- Terminal (hidden by default) -->
    <div id="terminal-container" class="terminal-container" role="application" aria-label="Terminal emulator">
      <Terminal
        client:only="react"
        key="terminal-component"
        onExit={() => {
          // Hide terminal without page reload
          window.hideTerminal();
        }}
      />
    </main>

    <!-- Terminal Control Script -->
    <script>
      // Make functions globally available
      window.showTerminal = function() {
        const terminal = document.getElementById('terminal-container');
        const body = document.body;

        if (!terminal || !body) {
          return;
        }

        // Show terminal
        body.classList.add('terminal-active');
        terminal.classList.add('active');

        // Focus terminal after it's rendered
        setTimeout(() => {
          const terminalInput = terminal.querySelector('textarea, input');
          if (terminalInput) {
            terminalInput.focus();
          }
        }, 100);
      };

      window.hideTerminal = function() {
        const terminal = document.getElementById('terminal-container');
        const body = document.body;
        const terminalButton = document.querySelector('[aria-controls="terminal-container"]');

        if (!terminal || !body) {
          return;
        }

        // Hide terminal
        body.classList.remove('terminal-active');
        terminal.classList.remove('active');

        // Reset aria-expanded state
        if (terminalButton) {
          terminalButton.setAttribute('aria-expanded', 'false');
        }

        // Return focus to terminal button for accessibility
        setTimeout(() => {
          if (terminalButton) {
            terminalButton.focus();
          }
        }, 100);
      };

      // Add keyboard listener for Escape key to exit terminal
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          const terminal = document.getElementById('terminal-container');
          const body = document.body;

          // Only exit if terminal is currently active
          if (terminal && body && terminal.classList.contains('active')) {
            window.hideTerminal();
          }
        }
      });
    </script>
  </body>
</html>