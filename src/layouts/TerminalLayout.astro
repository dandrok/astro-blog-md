---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Terminal from '../components/features/terminal/Terminal';

// Get all blog posts for the virtual file system
const blogPosts = await getCollection('blog');

// Generate virtual file system from blog content
const virtualFileSystem = {
  'about.md': {
    type: 'file',
    content: `# About This Terminal Blog

Welcome to the terminal interface of my blog!

## Available Commands:
- help - Show all available commands
- ls - List files and directories
- cd [dir] - Change directory
- cat [file] - Display file contents
- clear - Clear the terminal screen
- exit - Return to blog view

## Navigation:
This virtual file system contains all my blog posts. Navigate through the 'posts' directory to read different articles.

## Technology:
This blog is built with Astro, React, and TypeScript. The terminal mode uses jquery.terminal for an authentic command-line experience.

Enjoy exploring!
`
  },
  'posts': {
    type: 'dir',
    children: {}
  }
};

// Add all blog posts to the virtual file system
blogPosts.forEach(post => {
  const postContent = `# ${post.data.title}

**Published:** ${post.data.pubDate.toLocaleDateString()}
**Description:** ${post.data.description}

${post.body}

---
*Generated from ${post.slug}*`;

  virtualFileSystem['posts'].children[`${post.slug}.md`] = {
    type: 'file',
    content: postContent
  };
});

// Props interface
type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@xterm/css@5.5.0/xterm.css" />
    <style>
      :global(body) {
        margin: 0;
        padding: 0;
        font-family: 'VT323', monospace;
        background-color: var(--terminal-bg);
        color: var(--terminal-text);
        text-shadow: 0 0 3px var(--terminal-text);
        overflow-x: hidden;
      }

      /* Prevent body scrolling when in terminal mode */
      :global(body.interactive-mode) {
        overflow: hidden;
        width: 100%;
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
      }

      /* Override xterm default colors to match our terminal theme */
      :global(.xterm) {
        background-color: var(--terminal-bg) !important;
        color: var(--terminal-text) !important;
        font-family: 'VT323', monospace !important;
      }

      :global(.xterm-viewport) {
        background-color: var(--terminal-bg) !important;
      }

      :global(.xterm-screen) {
        background-color: var(--terminal-bg) !important;
      }

      :global(.xterm-selection) {
        background-color: rgba(0, 255, 0, 0.3) !important;
      }
    </style>
  </head>
  <body class="blog-mode">
    <!-- Blog Content (default mode) -->
    <div class="blog-content">
      <slot />
    </div>

    <!-- Terminal Container (hidden by default) -->
    <div class="terminal-container" id="terminal-container" style="display: none !important;">
      <Terminal
        client:only="react"
        key="terminal-component"
        fileSystem={virtualFileSystem}
        onExit={() => {
          // Simple page reload to exit terminal
          window.location.reload();
        }}
      />
    </div>

    <!-- Mode Toggle Script -->
    <script is:inline>
      // Make the function globally available
      window.toggleMode = function() {
        console.log('Toggle mode called'); // Debug log
        const body = document.body;
        const terminal = document.getElementById('terminal-container');
        const toggleButton = document.querySelector('.mode-toggle');

        console.log('Elements found:', { body: !!body, terminal: !!terminal, button: !!toggleButton });

        if (!body || !terminal || !toggleButton) {
          console.error('Required elements not found');
          return;
        }

        if (body.classList.contains('interactive-mode')) {
          console.log('Switching to blog mode'); // Debug log
          // Exit terminal mode - return to blog
          body.classList.remove('interactive-mode');
          body.classList.add('blog-mode');
          terminal.style.display = 'none';
          toggleButton.textContent = '[BLOG]';
          toggleButton.setAttribute('data-mode', 'blog');
        } else {
          console.log('Switching to terminal mode'); // Debug log
          // Enter terminal mode
          body.classList.remove('blog-mode');
          body.classList.add('interactive-mode');
          terminal.style.display = 'block';
          toggleButton.textContent = '[TERMINAL]';
          toggleButton.setAttribute('data-mode', 'terminal');

          // Focus terminal input after a short delay to ensure it's rendered
          setTimeout(() => {
            const terminalInput = terminal.querySelector('input');
            if (terminalInput) {
              terminalInput.focus();
              console.log('Terminal input focused'); // Debug log
            }
          }, 100);
        }
      };

      // Initialize the proper mode on page load
      function initializePage() {
        console.log('Initializing page mode'); // Debug log

        // Ensure we start in blog mode, not terminal mode
        const body = document.body;
        const terminal = document.getElementById('terminal-container');
        const toggleButton = document.querySelector('.mode-toggle');

        // Force blog mode on page load - remove any terminal classes
        if (body) {
          body.classList.remove('interactive-mode');
          body.classList.add('blog-mode');
          console.log('Body classes:', body.className); // Debug log
        }
        if (terminal) {
          terminal.style.display = 'none';
          console.log('Terminal hidden'); // Debug log
        }
        if (toggleButton) {
          toggleButton.textContent = '[BLOG]';
          toggleButton.setAttribute('data-mode', 'blog');
          console.log('Button set to [BLOG]'); // Debug log
        }

        console.log('Page initialized to blog mode'); // Debug log
      }

      // Wait for DOM to be ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializePage);
      } else {
        // DOM already loaded
        initializePage();
      }

      // Also initialize after a short delay to ensure everything is loaded
      setTimeout(initializePage, 100);

          </script>
  </body>
</html>