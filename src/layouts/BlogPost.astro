---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import SiteLayout from './SiteLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Prose from '../components/common/Prose.astro';
import TagList from '../components/common/TagList.astro';
import TerminalTitle from '../components/common/TerminalTitle.astro';
import PageHeader from '../components/common/PageHeader.astro';
import TableOfContents from '../components/features/blog/TableOfContents.astro';

type Props = CollectionEntry<'blog'>['data'] & {
  headings?: MarkdownHeading[];
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroImageAlt,
  tags = [],
  headings = [],
} = Astro.props;
---

<SiteLayout title={title} description={description}>
  <main id="main-content" class="relative z-[2] mx-auto max-w-6xl px-6 py-8 pb-16">
    <PageHeader showBackButton={true} backUrl="/blog/" />

    <div class="lg:grid lg:grid-cols-[1fr_250px] lg:gap-12">
      <article class="min-w-0 space-y-8">
        <!-- Hero image with consistent spacing -->
        {
          heroImage && (
            <div class="mb-8">
              <Image
                width={1020}
                height={510}
                src={heroImage}
                alt={heroImageAlt || title}
                class="h-auto w-full max-w-full rounded border-2 border-green-400/30 shadow-lg shadow-green-400/10"
              />
            </div>
          )
        }

        <!-- Article header with improved typography -->
        <header class="space-y-4 border-b border-green-400/30 pb-8">
          <div class="space-y-2 text-sm text-green-400">
            <p>~/blog/{Astro.params?.slug || title.toLowerCase().replace(/\s+/g, '-')}</p>
            <time datetime={pubDate.toISOString()} class="block">
              Published: <FormattedDate date={pubDate} />
            </time>
            {
              updatedDate && (
                <time datetime={updatedDate.toISOString()} class="block text-green-500">
                  Last updated: <FormattedDate date={updatedDate} />
                </time>
              )
            }
          </div>

          <TerminalTitle title={title} level={1} />

          <TagList tags={tags} class="pt-2" />
        </header>

        <!-- Article content with terminal-themed prose styling -->
        <div class="prose-wrapper">
          <Prose>
            <slot />
          </Prose>
        </div>
      </article>

      {/*
        TOC column: sticky + self-start on the grid item so the sidebar pins
        under the header for the full article height (lg+ only).
      */}
      <aside class="sticky top-[100px] hidden max-h-[calc(100vh_-_150px)] w-[250px] self-start overflow-y-auto lg:block">
        <TableOfContents headings={headings} />
      </aside>
    </div>
  </main>
</SiteLayout>
