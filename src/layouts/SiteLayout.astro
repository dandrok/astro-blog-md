---
import BaseHead from '../components/BaseHead.astro';
import ScrollToTop from '../components/common/ScrollToTop.astro';
import Footer from '../components/Footer.astro';

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    {/* FOUC: apply theme + preset before first paint (must stay is:inline). */}
    <script is:inline>
      (() => {
        try {
          const root = document.documentElement;
          const savedTheme = localStorage.getItem('theme');
          const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          const theme =
            savedTheme === 'light' || savedTheme === 'dark'
              ? savedTheme
              : prefersLight
                ? 'light'
                : 'dark';
          root.dataset.theme = theme;

          const savedUi = localStorage.getItem('ui-mode');
          const uiMode = savedUi === 'regular' || savedUi === 'terminal' ? savedUi : 'terminal';
          root.dataset.uiMode = uiMode;
          if (uiMode === 'terminal') {
            root.dataset.kbPreset = 'terminal';
          } else {
            delete root.dataset.kbPreset;
          }
        } catch {
          /* private mode / blocked storage */
        }
      })();
    </script>
  </head>
  <body>
    {/*
      Register kitbash CEs at the *start* of <body> (not after footer).
      Module scripts are deferred (run after full parse), but the browser starts
      downloading as soon as it hits this tag — on long posts a trailing script
      only begins fetch after the whole article HTML is parsed.
    */}
    <script>
      import '../scripts/kitbash.ts';
    </script>

    <slot />

    <Footer />
    <ScrollToTop />

    <script is:inline>
      console.log(
        '%c$ cd%c ~/.file',
        'color:#00ff41;font-weight:bold;font-size:16px;',
        'color:#d1fae5;font-size:16px;',
      );

      console.log(
        '%cLoaded personal site config.%c\n%cIf you want to connect or talk about code, tools, or ideas:%c\n%chttps://github.com/dandrok%c',
        'color:#4ade80;font-size:14px;',
        'color:inherit;',
        'color:#4ade80;font-size:13px;',
        'color:inherit;',
        'color:#d1fae5;font-size:13px;text-decoration:underline;',
        'color:inherit;',
      );
    </script>
  </body>
</html>
