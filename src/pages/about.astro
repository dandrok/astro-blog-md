---
import SiteLayout from '../layouts/SiteLayout.astro';
import Prose from '../components/common/Prose.astro';
import PageHeader from '../components/common/PageHeader.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<SiteLayout title="About" description={SITE_DESCRIPTION}>
  <main id="main-content" class="mx-auto min-h-screen max-w-6xl px-6 py-8 pb-16">
    <PageHeader showBackButton={true} />

    <div class="space-y-8">
      <section class="mb-12">
        <Prose>
          <h1 class="mb-4 text-4xl font-semibold text-green-300">&gt; ~/about</h1>
        </Prose>
      </section>

      <section>
        <Prose>
          <h2>Profile</h2>
          <pre><code>$ cat ~/.file/profile

role=fe software engineer
focus=react,typescript
interests=retro-ui,small-tools,ai-tooling
location=internet</code></pre>

          <h2>Work</h2>
          <pre><code>$ cat ~/.config/work/history.ini

[stepstone]
role=software engineer - frontend
period=2021-present
work=multi-tenant react applications, auth, onboarding, ai integration

[promitel]
role=webmaster / web admin
period=2019-2021
work=technical troubleshooting and web administration</code></pre>

          <h2>Tooling</h2>
          <pre><code>$ cat ~/.config/work/tooling.ini

frontend=react,nextjs,redux,tailwind,storybook
delivery=git,webpack,bamboo,optimizely
systems=linux,macos,vim,neovim</code></pre>

          <h2>AI</h2>
          <pre><code>$ cat ~/.config/work/ai.ini

interest=high
focus=coding agents,llm tooling,mcp,local and hosted models,workflow automation
stack=codex,claude,gemini,deepseek,z-ai,ollama
usage=code generation,review,automation,research</code></pre>

          <h2>Why This Exists</h2>
          <p>
            I wanted a personal site that feels closer to browsing someone's home directory than
            scrolling through a polished corporate landing page.
          </p>
          <p>
            The idea behind <strong>.file</strong> is simple: treat notes, projects, and writing like
            small files you can open, inspect, and come back to later.
          </p>

          <h2>Current Focus</h2>
          <ul>
            <li>Frontend architecture with React and TypeScript.</li>
            <li>Terminal user interfaces (TUIs), browser extensions, and workflow automations.</li>
            <li>AI-assisted developer workflows that improve productivity without adding noise.</li>
          </ul>

          <h2>Links</h2>
          <pre><code>$ cat ~/.file/links

<a href="https://github.com/dandrok" target="_blank" rel="noopener noreferrer">github=github.com/dandrok</a>
<a href="mailto:patryk.stusik@gmail.com">email=patryk.stusik@gmail.com</a>
<a href="/about/">about=/about/</a>
<a href="/blog/">writing=/blog/</a>
<a href="/rss.xml">rss=/rss.xml</a></code></pre>
        </Prose>
      </section>
    </div>
  </main>
</SiteLayout>
