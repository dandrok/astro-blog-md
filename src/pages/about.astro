---
import SiteLayout from '../layouts/SiteLayout.astro';
import Prose from '../components/common/Prose.astro';
import PageHeader from '../components/common/PageHeader.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<SiteLayout title={`${SITE_TITLE} - About`} description={SITE_DESCRIPTION}>
  <main id="main-content" class="max-w-6xl mx-auto px-6 py-8 pb-16 min-h-screen font-mono">
    <PageHeader showBackButton={true} />

    <div class="space-y-8">
      <section class="mb-12">
        <Prose>
          <h1 class="text-4xl text-green-300 font-semibold mb-4">
            > ~/about
          </h1>
          <p class="text-green-500 text-lg">
            Personal config, not a corporate bio.
          </p>
        </Prose>
      </section>

      <section>
        <Prose>
          <h2>Profile</h2>
          <pre><code>$ cat ~/.file/profile

name=dandrok
role=software engineer
focus=cli,tui,systems,astro
interests=retro-ui,writing,small-tools
location=internet</code></pre>

          <h2>Shell</h2>
          <pre><code>$ cat ~/.bashrc

alias build="astro build"
alias write="open editor and keep it simple"
export THEME="dotfile"
export STYLE="terminal-inspired"
export OUTPUT="notes, projects, experiments"</code></pre>

          <h2>Git Config</h2>
          <pre><code>$ cat ~/.gitconfig

[user]
  name = dandrok

[work]
  preference = practical over clever
  bias = simple tools, readable systems
  notes = ship clean things and keep improving them</code></pre>

          <h2>Site Config</h2>
          <pre><code>$ cat ~/.config/work/profile.ini

[site]
name=.file
domain=thedotfile.com
stack=astro,markdown,tailwind
theme=dotfiles + terminal

[content]
posts=projects, write-ups, experiments
style=short, direct, readable</code></pre>

          <h2>Why This Exists</h2>
          <p>
            I wanted a personal site that feels closer to browsing someone's home directory than scrolling through a polished corporate landing page.
          </p>
          <p>
            The idea behind <strong>.file</strong> is simple: treat notes, projects, and writing like small files you can open, inspect, and come back to later.
          </p>

          <h2>Current Focus</h2>
          <ul>
            <li>Building practical CLI and TUI tools.</li>
            <li>Writing about projects in a simple, useful way.</li>
            <li>Keeping the site lightweight and easy to maintain.</li>
          </ul>

          <h2>Links</h2>
          <pre><code>$ cat ~/.file/links

github=github.com/dandrok
about=/about/
writing=/blog/
rss=/rss.xml</code></pre>
        </Prose>
      </section>
    </div>
  </main>
</SiteLayout>
