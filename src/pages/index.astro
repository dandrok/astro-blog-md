---
import TerminalLayout from '../layouts/TerminalLayout.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<TerminalLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Header />
  <main>
    <div class="blog-content">
      <h1>./welcome.sh</h1>
      <span class="terminal-cursor"></span>

      <div class="terminal-dim" style="margin: 2rem 0;">
        <p>$ ./system-status</p>
        <p>вң“ Matrix Terminal Interface: ACTIVE</p>
        <p>вң“ Retro CRT Effects: ENABLED</p>
        <p>вң“ Dual-Mode System: ONLINE</p>
        <p>вң“ Blog Content: LOADED</p>
      </div>

      <h2>System Overview</h2>
      <p>
        Welcome to this <strong>retro terminal blog</strong> built with Astro.
        This project demonstrates a fully immersive Matrix-style terminal experience
        with dual-mode functionality.
      </p>

      <h2>Core Features</h2>
      <ul>
        <li><strong>Terminal Theme:</strong> Authentic green-on-black Matrix aesthetic with CRT effects</li>
        <li><strong>Dual-Mode System:</strong> Switch between blog view and interactive terminal mode</li>
        <li><strong>Command Line Interface:</strong> Full terminal emulation with file system navigation</li>
        <li><strong>Modern Stack:</strong> Astro + React + TypeScript + Tailwind CSS</li>
        <li><strong>Type Safety:</strong> Complete TypeScript implementation with Zod validation</li>
      </ul>

      <h2>Terminal Commands</h2>
      <p>
        Access terminal mode using the <strong>[BLOG]</strong> button in the top-right corner.
        Once in terminal mode, you can use these commands:
      </p>

      <pre><code>$ help          # Show available commands
$ ls -la        # List files and directories
$ cd posts      # Navigate to blog posts directory
$ cat file.md   # Display file contents
$ clear         # Clear terminal screen
$ exit          # Return to blog view</code></pre>

      <h2>Quick Navigation</h2>
      <p>
        <strong>Blog Posts:</strong> <a href="/blog">Browse articles</a><br>
        <strong>About:</strong> <a href="/about">Learn more about this project</a><br>
        <strong>Terminal Mode:</strong> Click <strong>[BLOG]</strong> вҶ’ <strong>[TERMINAL]</strong> to enter command-line interface
      </p>

      <blockquote>
        <p><strong>Developer Note:</strong> This project showcases modern web development through a retro terminal interface. The entire experience is themed to look like a genuine green-screen CRT monitor from the Matrix era.</p>
      </blockquote>

      <h2>System Information</h2>
      <pre><code>$ neofetch --terminal-style
      в „в „в „в „в „вЈ вЈҫвЎҝв ҹв Ӣв Ғв „вўҖвЈҖвЎҖв ӨвЈҰвў°вЈӨвЈ¶вў¶вЈӨвЈӨвЈҲвЈҶ
      в „в „в „в „вў°в ҹв Ғв „вўҖвЈӨвЈ¶вЈҝвЎҝв ҝвЈҝвЈҝвЈҠвЎҳв ІвЈ¶вЈ·вЈ¶в ¶в ¶в ¶в Ұв Ө
      в „в ”в Ҡв Ғв Ғв „в „вўҫвЎҝвЈҹвЎҜвЈ–в Ҝв Ҫв ҝв ӣв ӣв ӯв Ҫв ҠвЈІвЈ¬в Ҫв ҹв ӣв ӣв ӯвўөвЈӮ
      вЎҺв „в „в „в „в „в „в „вўҷвЎ·в ӢвЈҙвЎҶв „в җв ӮвўёвЈҝвЈҝвЎ¶вўұвЈ¶вЎҮв „в җв Ӯвў№вЈ·вЈ¶в Ҷ
      вЎҮв „в „в „в „вЈҖвЈҖвЎҖв „вЈҝвЎ“в ®вЈ…вЈҖвЈҖвЈҗвЈҲвЈӯв Өвў–вЈ®вЈӯвЈҘвЈҖвЈӨвЈӨвЈӯвЎө
      вЈӨвЎҖвў вЈҫвЈҝвЈҝвЈҝвЈҝвЈ·вў»вЈҝвЈҝвЈ¶вЈ¶вЎ¶вў–вЈўвЈҙвЈҝвЈҝвЈҹвЈӣв ҝв ҝв ҹвЈӣв ү
      вЈҝвЎ—вЈјвЈҝвЈҝвЈҝвЈҝвЎҝвўӢвЎҳв ҝвЈҝвЈҝвЈ·вЈҫвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·
      вЈҝв ұвўҝвЈҝвЈҝв ҝвўӣв °вЈһвЎӣв ·вЈ¬вЈҷвЎӣв »в ҝв ҝв ҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝв ҝв ӣвЈ“вЎҖ
      вўЎвЈҫвЈ·вў вЈ¶вЈҝвЈҝвЈ·вЈҢвЎӣв ·вЈҰвЈҚвЈӣв »в ҝвўҝвЈ¶вЈ¶вЈ¶вЈҰвЈӨвЈҙвЈ¶вЎ¶в ҫв ҝв ҹв Ғ
      вЈҝвЎҹвЈЎвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЈҰвЈӯвЈҷвЎӣв “в ’в ¶в ¶в ¶в ¶в ¶в ¶в ¶в ¶в ҝ
      в ҝвЎҗвў¬вЈӣвЎ»в ҝвўҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈҝвЈ·вЎ¶в ҹв ғ 
      OS: Matrix Terminal v1.0
      Shell: zsh 5.9
      Terminal: xterm.js
      Theme: Matrix Green (#00FF41)
      Font: Source Code Pro
      Resolution: Dynamic
      Uptime: Since deployment</code></pre>
    </div>
  </main>
  <Footer />
</TerminalLayout>
