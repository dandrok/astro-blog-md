---
import TerminalLayout from '../layouts/TerminalLayout.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Prose from '../components/common/Prose.astro';
import TerminalTitle from '../components/common/TerminalTitle.astro';
import TerminalCommand from '../components/common/TerminalCommand.astro';
import TerminalTip from '../components/common/TerminalTip.astro';
import TerminalText from '../components/common/TerminalText.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<TerminalLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Header />
  <main class="max-w-4xl mx-auto px-6 py-8 pb-16 relative z-[2]">
    <Prose>
      <TerminalTitle title="~/welcome ❯" level={1} />
      <TerminalTitle title="Introduction" level={2} showCursor={false} />
      <TerminalText content="the .file this is the space where I publish my thoughts, ideas, and projects" strongWords={["the .file"]} />

      <TerminalTitle title="Terminal Commands" level={2} showCursor={false} />
      <TerminalText content="Access terminal mode using the TERMINAL button in the header. Once in terminal mode, you can use these commands:" strongWords={["TERMINAL"]} />

      <!-- Terminal command examples with better spacing -->
      <div class="bg-black/50 border border-green-400/30 rounded p-6 my-8">
        <pre class="text-green-400 font-mono text-sm leading-relaxed overflow-x-auto"><code>$ help      # Show available commands
$ ls -la    # List files and directories
$ cd posts  # Navigate to blog posts directory
$ cat file.md # Display file contents
$ clear     # Clear terminal screen
$ exit      # Return to blog view</code></pre>
      </div>

      <TerminalTitle title="Quick Navigation" level={2} showCursor={false} />

      <!-- Navigation links with consistent spacing -->
      <div class="space-y-4 my-8">
        <div class="flex items-center gap-4 p-4 border border-green-400/20 rounded hover:border-green-400/40 transition-colors">
          <span class="text-green-300 font-semibold min-w-[100px]">Blog Posts:</span>
          <a href="/blog" class="text-green-400 no-underline hover:text-green-300 transition-colors underline-dotted">Browse all articles</a>
        </div>

        <div class="flex items-center gap-4 p-4 border border-green-400/20 rounded hover:border-green-400/40 transition-colors">
          <span class="text-green-300 font-semibold min-w-[100px]">About:</span>
          <a href="/about" class="text-green-400 no-underline hover:text-green-300 transition-colors underline-dotted">Learn more about this project</a>
        </div>

        <div class="flex items-center gap-4 p-4 border border-green-400/20 rounded hover:border-green-400/40 transition-colors">
          <span class="text-green-300 font-semibold min-w-[100px]">Terminal:</span>
          <span>Click <strong class="text-green-200">[TERMINAL]</strong> to enter command-line interface</span>
        </div>
      </div>

      <TerminalTip
        title="DEVELOPER NOTE"
        content="This project showcases modern web development through a retro terminal interface. The entire experience is themed to look like a genuine green-screen CRT monitor from the Matrix era."
        type="note"
      />
    </Prose>
  </main>
  <Footer />
</TerminalLayout>
